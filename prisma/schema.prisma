generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["views"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model actions {
  id          Int           @id @default(autoincrement())
  description String?       @db.VarChar(255)
  slug        String?       @db.VarChar(255)
  permissions permissions[]
}

model module {
  id          Int           @id @default(autoincrement())
  name        String?       @db.VarChar(255)
  description String?       @db.VarChar(255)
  module      String?       @db.VarChar(255)
  uuid        String?       @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug        String?       @db.VarChar(255)
  permissions permissions[]
}

model permissions {
  id               Int                @id @default(autoincrement())
  code             String?            @db.VarChar(255)
  name             String?            @db.VarChar(255)
  description      String?            @db.VarChar(255)
  is_active        Boolean?           @default(true)
  action_id        Int?
  module_id        Int?
  actions          actions?           @relation(fields: [action_id], references: [id], onUpdate: NoAction)
  module           module?            @relation(fields: [module_id], references: [id], onUpdate: NoAction)
  role_permissions role_permissions[]
  user_permissions user_permissions[]

  @@index([action_id], map: "idx_permissions_action")
  @@index([module_id], map: "idx_permissions_module")
}

model role {
  idrole                     Int                @id @default(autoincrement())
  description                String?            @db.VarChar(255)
  is_super                   Boolean?           @default(false)
  hierarchy_level            Int?
  role_permissions           role_permissions[]
  sysUser_sysUser_roleTorole sysUser[]          @relation("sysUser_roleTorole")
}

model role_permissions {
  id            Int         @id @default(autoincrement())
  role_id       Int
  permission_id Int
  is_active     Boolean?    @default(true)
  permissions   permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  role          role        @relation(fields: [role_id], references: [idrole], onDelete: Cascade, onUpdate: NoAction)

  @@index([permission_id], map: "idx_roleperm_permission")
  @@index([role_id], map: "idx_roleperm_role")
}

model user_permissions {
  id            Int         @id @default(autoincrement())
  idsysuser     Int
  id_permission Int
  permissions   permissions @relation(fields: [id_permission], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sysuser       sysUser     @relation(fields: [idsysuser], references: [idsysUser], onDelete: Cascade, onUpdate: NoAction)

  @@index([id_permission], map: "idx_userperm_permission")
  @@index([idsysuser], map: "idx_userperm_user")
}

model user_status {
  id_user_status Int       @id @default(autoincrement())
  status_name    String?   @db.VarChar(255)
  sysUser        sysUser[]
}

model sysUser {
  idsysUser                     Int                @id(map: "sysuser_pkey") @default(autoincrement())
  role                          Int?
  uuid                          String?            @default(dbgenerated("gen_random_uuid()")) @db.VarChar(255)
  userEmail                     String?            @db.VarChar(255)
  userName                      String?            @db.VarChar(255)
  userLastName                  String?            @db.VarChar(255)
  userPhone                     String?            @db.VarChar(50)
  created_at                    DateTime?          @default(now()) @db.Timestamp(6)
  updated_at                    DateTime?          @default(now()) @db.Timestamp(6)
  sysuserstatus_idsysuserstatus Int?
  userPassword                  String?            @db.VarChar(255)
  loggedbyfirsttime             Boolean?           @default(false)
  is_active                     Boolean?           @default(true)
  activation_token              String?            @db.VarChar(255)
  activation_expires            DateTime?          @db.Timestamp(6)
  reset_password_token          String?            @db.VarChar(255)
  reset_password_expires        DateTime?          @db.Timestamp(6)
  role_sysUser_roleTorole       role?              @relation("sysUser_roleTorole", fields: [role], references: [idrole], onUpdate: NoAction, map: "sysuser_role_idrole_fkey")
  user_status                   user_status?       @relation(fields: [sysuserstatus_idsysuserstatus], references: [id_user_status], onUpdate: NoAction, map: "sysuser_sysuserstatus_idsysuserstatus_fkey")
  user_permissions              user_permissions[]

  @@index([role], map: "idx_sysuser_role")
  @@index([sysuserstatus_idsysuserstatus], map: "idx_sysuser_status")
}
