# =====================================================
# GENERIC SAAS FRAMEWORK - ENVIRONMENT VARIABLES
# =====================================================

# =====================================================
# DATABASE CONFIGURATION
# =====================================================
DATABASE_URL="postgresql://postgres:Pa970419@localhost:5432/galatea?schema=public"

# =====================================================
# REDIS CONFIGURATION
# =====================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600

# =====================================================
# JWT AUTHENTICATION
# =====================================================
JWT_SECRET=change_this_to_a_very_secure_random_string_min_256_bits
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=change_this_to_another_very_secure_random_string
JWT_REFRESH_EXPIRES_IN=7d

# =====================================================
# APPLICATION CONFIGURATION
# =====================================================
APP_NAME=SaaSFramework
APP_PORT=3000
NODE_ENV=development
API_PREFIX=api
CORS_ORIGIN=http://localhost:4200,http://localhost:3001

# =====================================================
# MULTI-TENANCY
# =====================================================
DEFAULT_TENANT_ID=development
TENANT_HEADER=x-tenant-id

# =====================================================
# GOOGLE CLOUD STORAGE (Optional)
# =====================================================
GCS_BUCKET_NAME=app-uploads
GCS_UPLOAD_PATH=uploads
GCS_PROJECT_ID=your-gcp-project-id
GCS_CREDENTIALS_PATH=./credentials.json
# Or use GOOGLE_APPLICATION_CREDENTIALS environment variable

# =====================================================
# STRIPE PAYMENT INTEGRATION (Optional)
# =====================================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PUBLIC_KEY=pk_test_your_public_key
STRIPE_API_VERSION=2023-10-16

# =====================================================
# TWILIO SMS/MESSAGING (Optional)
# =====================================================
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_MESSAGING_SERVICE_SID=

# =====================================================
# EMAIL CONFIGURATION (Optional)
# =====================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@yoursaas.com

# =====================================================
# AWS S3 (Alternative to GCS - Optional)
# =====================================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# =====================================================
# SECURITY CONFIGURATION
# =====================================================
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
BCRYPT_ROUNDS=10
SESSION_SECRET=change_this_to_a_secure_session_secret

# =====================================================
# LOGGING & MONITORING
# =====================================================
LOG_LEVEL=debug
LOG_FILE=./logs/app.log
SENTRY_DSN=

# =====================================================
# WEBHOOKS CONFIGURATION
# =====================================================
WEBHOOK_SECRET=your_webhook_verification_secret

# =====================================================
# EXTERNAL SERVICES (Optional)
# =====================================================
AUTHORIZATION_SERVICE_URL=http://localhost:3001/api/auth
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
OPENAI_API_KEY=

# =====================================================
# FEATURE FLAGS (Default values)
# =====================================================
ENABLE_AI_FEATURES=true
ENABLE_WEBHOOKS=true
ENABLE_WEBSOCKETS=true
ENABLE_ADVANCED_ANALYTICS=false

# =====================================================
# DEVELOPMENT TOOLS
# =====================================================
SWAGGER_ENABLED=true
DEBUG_MODE=true
