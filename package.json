    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "node scripts/load-env.js development -- nest start --watch",
    "start:debug": "node scripts/load-env.js development -- nest start --debug --watch",
    "start:prod": "node scripts/load-env.js production -- nest start",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:pull": "dotenv -e .env -- npx prisma db pull && npx prisma generate",
    "db:generate": "npx prisma generate"
  },
